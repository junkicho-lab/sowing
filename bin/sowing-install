#!/usr/bin/env bash
# Sowing 🌱 — 한 줄 설치 스크립트.
#
# 사용:
#   curl -fsSL https://raw.githubusercontent.com/junkicho-lab/sowing/main/bin/sowing-install | bash
#
# 또는 로컬:
#   git clone https://github.com/junkicho-lab/sowing.git && cd sowing && ./bin/sowing-install
#
# 동작:
#   1. OS 탐지 (macOS / Linux)
#   2. Ruby 3.3+ 확인 — 없으면 안내
#   3. 저장소 clone (없으면) 또는 업데이트 (있으면)
#   4. bundle install
#   5. db:setup
#   6. 첫 실행 안내

set -euo pipefail

REPO_URL="https://github.com/junkicho-lab/sowing.git"
INSTALL_DIR="${SOWING_INSTALL_DIR:-$HOME/.sowing/app}"
MIN_RUBY="3.3.0"

# ─── 색 ───
green() { printf "\033[32m%s\033[0m\n" "$*"; }
yellow() { printf "\033[33m%s\033[0m\n" "$*"; }
red() { printf "\033[31m%s\033[0m\n" "$*" >&2; }
bold() { printf "\033[1m%s\033[0m\n" "$*"; }

bold "🌱 Sowing 설치 스크립트"
echo "─────────────────────────────"

# ─── 1. OS 탐지 ───
OS="$(uname -s)"
case "$OS" in
  Darwin) PLATFORM="macos"; PKG_MGR="brew" ;;
  Linux)
    PLATFORM="linux"
    if command -v apt-get >/dev/null 2>&1; then PKG_MGR="apt"
    elif command -v dnf >/dev/null 2>&1; then PKG_MGR="dnf"
    elif command -v pacman >/dev/null 2>&1; then PKG_MGR="pacman"
    else PKG_MGR="unknown"; fi
    ;;
  *)
    red "❌ 지원 안 하는 OS: $OS"
    red "   Windows 는 WSL2 또는 Docker 사용 — docker-compose.yml 참조."
    exit 1
    ;;
esac
green "✅ OS: $PLATFORM ($PKG_MGR)"

# ─── 2. Ruby 확인 ───
if ! command -v ruby >/dev/null 2>&1; then
  red "❌ Ruby 가 설치돼 있지 않습니다."
  echo ""
  echo "Ruby ${MIN_RUBY} 이상 설치 후 재실행:"
  case "$PLATFORM" in
    macos) echo "  brew install ruby   # 또는 mise/rbenv/asdf 권장" ;;
    linux) echo "  apt install ruby-full   # 또는 mise/rbenv/asdf 권장" ;;
  esac
  echo ""
  echo "권장: mise (https://mise.jdx.dev) — 프로젝트별 Ruby 버전 관리"
  echo "  curl https://mise.run | sh"
  echo "  mise use --global ruby@3.3"
  exit 1
fi

RUBY_VERSION="$(ruby -e 'print RUBY_VERSION')"
RUBY_MAJOR=$(echo "$RUBY_VERSION" | cut -d. -f1)
RUBY_MINOR=$(echo "$RUBY_VERSION" | cut -d. -f2)
if [ "$RUBY_MAJOR" -lt 3 ] || { [ "$RUBY_MAJOR" -eq 3 ] && [ "$RUBY_MINOR" -lt 3 ]; }; then
  red "❌ Ruby ${RUBY_VERSION} — Sowing 은 ${MIN_RUBY} 이상 필요"
  exit 1
fi
green "✅ Ruby $RUBY_VERSION"

# ─── 3. Bundler 확인 ───
if ! command -v bundle >/dev/null 2>&1; then
  yellow "⚠  Bundler 미설치 — 설치 시도"
  gem install bundler --no-document
fi
green "✅ Bundler $(bundle --version | awk '{print $NF}')"

# ─── 4. Git ───
if ! command -v git >/dev/null 2>&1; then
  red "❌ Git 미설치 — 먼저 설치하세요:"
  case "$PLATFORM" in
    macos) echo "  xcode-select --install" ;;
    linux) echo "  apt install git   # 또는 dnf/pacman" ;;
  esac
  exit 1
fi
green "✅ Git $(git --version | awk '{print $3}')"

# ─── 5. Clone or update ───
echo ""
if [ -d "$INSTALL_DIR/.git" ]; then
  bold "📂 기존 설치 발견: $INSTALL_DIR"
  echo "   업데이트 시도..."
  cd "$INSTALL_DIR"
  git fetch --quiet
  git pull --ff-only origin main || {
    yellow "⚠  자동 업데이트 실패 — 수동 해결 후 재실행"
    yellow "   cd $INSTALL_DIR && git status"
    exit 1
  }
else
  bold "📦 저장소 clone: $REPO_URL → $INSTALL_DIR"
  mkdir -p "$(dirname "$INSTALL_DIR")"
  git clone "$REPO_URL" "$INSTALL_DIR"
  cd "$INSTALL_DIR"
fi

# ─── 6. Bundle install ───
echo ""
bold "💎 Gem 의존성 설치..."
bundle config set --local without "development test"
bundle install --jobs 4 --retry 3

# ─── 7. DB setup ───
echo ""
bold "🗃  DB 셋업..."
bundle exec rake db:setup

# ─── 8. doctor 진단 ───
echo ""
bold "🔍 시스템 진단..."
./bin/sowing-doctor || true

# ─── 9. 첫 실행 안내 ───
echo ""
echo "─────────────────────────────"
green "✅ 설치 완료"
echo ""
bold "다음 단계:"
echo ""
echo "  cd $INSTALL_DIR"
echo "  ./bin/sowing dev          # http://127.0.0.1:48723 에서 접속"
echo ""
echo "또는 별칭 등록:"
case "$PLATFORM" in
  macos) PROFILE="$HOME/.zshrc" ;;
  linux) PROFILE="$HOME/.bashrc" ;;
esac
echo "  echo 'alias sowing=\"$INSTALL_DIR/bin/sowing\"' >> $PROFILE"
echo "  source $PROFILE"
echo ""
echo "Vault 위치: \${SOWING_VAULT:-~/Documents/SowingVault}"
echo "데이터 위치: ~/.local/share/Sowing (Linux) / ~/Library/Application Support/Sowing (macOS)"
echo ""
echo "도움말:"
echo "  ./bin/sowing-doctor       # 진단"
echo "  ./bin/sowing memo \"...\"   # CLI 메모"
echo "  http://127.0.0.1:48723/onboarding/welcome   # 첫 실행 마법사"
echo ""
green "🌱 Sowing 시작!"
