#!/usr/bin/env ruby
# frozen_string_literal: true

# Sowing 진단 도구.
# 환경 정보, 볼트 무결성, 인덱스 일관성 등을 점검.

require "bundler/setup"
require_relative "../config/application"

puts "🔍 Sowing Doctor — 진단 시작"
puts "─" * 60

# 진단 결과 누적기 — 마지막에 5종 흔한 문제 진단(W8-T06) 요약 출력.
issues = []

# 1. 환경
puts "\n[환경]"
puts "  Ruby:        #{RUBY_VERSION} (#{RUBY_PLATFORM})"
puts "  Sowing:      #{Sowing::VERSION}"
puts "  SOWING_ENV:  #{Sowing.env}"
puts "  Encoding:    external=#{Encoding.default_external.name}"
if Encoding.default_external != Encoding::UTF_8
  issues << "외부 인코딩이 UTF-8이 아님 — 한국어 파일명/내용이 깨질 수 있음. LANG=ko_KR.UTF-8 설정 권장"
end

# Ruby 버전 검증 (Gemfile은 ~> 4.0 가정)
ruby_major = RUBY_VERSION.split(".")[0].to_i
if ruby_major < 3
  issues << "Ruby #{RUBY_VERSION} 너무 낮음 (3.0+ 필요) — `rbenv install`/`mise install` 또는 시스템 Ruby 업그레이드"
end

# 2. 경로
puts "\n[경로]"
puts "  데이터 디렉토리: #{Sowing::Infrastructure::Paths.data_dir}"
puts "  볼트:           #{Sowing::Infrastructure::Paths.vault_dir}"
puts "  DB:             #{Sowing::Infrastructure::Paths.db_path}"

# 3. 디렉토리 존재 + 쓰기 권한 + 디스크 여유
puts "\n[디렉토리 상태]"
[
  ["데이터", Sowing::Infrastructure::Paths.data_dir.to_s],
  ["볼트", Sowing::Infrastructure::Paths.vault_dir.to_s]
].each do |label, path|
  if File.directory?(path)
    if File.writable?(path)
      puts "  ✅ #{label}: 존재 + 쓰기 가능"
    else
      puts "  ❌ #{label}: 존재하나 쓰기 권한 없음"
      issues << "#{label} 디렉토리에 쓰기 권한 없음 (#{path}) — `chmod u+w` 또는 소유자 확인"
    end
  else
    puts "  ⚠  #{label}: 없음 — bin/sowing dev 실행 시 자동 생성됨"
  end
end

# 디스크 여유 — `df` 명령으로 홈 파티션 가용 공간 확인 (sys-filesystem gem 의존 회피)
begin
  df_output = `df -k "#{Dir.home}" 2>/dev/null`.lines.last
  if df_output && (parts = df_output.split).size >= 4
    free_kb = parts[3].to_i
    free_mb = free_kb / 1024
    if free_mb < 100
      puts "  ⚠  홈 파티션 여유: #{free_mb} MB"
      issues << "디스크 여유 #{free_mb}MB — 메모/필기/기록 작성에 지장. 정리 권장"
    end
  end
rescue
  # df 미지원 OS는 skip
end

# 4. DB 연결 + 인덱스 통계
puts "\n[DB / 인덱스]"
begin
  db = Sowing::Infrastructure::DB.connection
  tables = db.tables
  puts "  ✅ 연결 성공 (테이블 #{tables.size}개: #{tables.sort.join(", ")})"

  if tables.include?(:entries)
    total = db[:entries].count
    by_mode = db[:entries].group_and_count(:mode).all
    puts "  entries 총 #{total}건"
    by_mode.each { |row| puts "    · #{row[:mode]}: #{row[:count]}건" } unless by_mode.empty?
  else
    puts "  ⚠  entries 테이블 없음 — bundle exec rake db:setup 필요"
  end

  if tables.include?(:tags)
    tag_total = db[:tags].count
    puts "  tags 총 #{tag_total}개"
    if tag_total > 0
      top = db[:tags]
        .join(:entry_tags, tag_id: :id)
        .group_and_count(Sequel[:tags][:name])
        .order(Sequel.desc(:count))
        .limit(5)
        .all
      top.each { |row| puts "    · #{row[:name]} (#{row[:count]}회 사용)" }
    end
  end

  if tables.include?(:links)
    link_total = db[:links].count
    broken_count = db[:links].where(target_id: nil).count
    puts "  links 총 #{link_total}건 (broken #{broken_count}건)"
    if broken_count > 0
      top_broken = db[:links].where(target_id: nil)
        .group_and_count(:target_text)
        .order(Sequel.desc(:count))
        .limit(5)
        .all
      top_broken.each { |row| puts "    ⚠  [[#{row[:target_text]}]] (#{row[:count]}회 깨짐)" }
    end
  end

  if tables.include?(:entries)
    promoted_count = db[:entries].exclude(promoted_from: nil).count
    puts "  승격된 entries: #{promoted_count}건" if promoted_count > 0
  end

  # FTS5 인덱스 정합성 (W4-T01) + SQLite 버전 (3.34+ 필요 — trigram 토크나이저).
  sqlite_version = db.fetch("SELECT sqlite_version() AS v").first[:v]
  puts "  SQLite:     #{sqlite_version}"
  if Gem::Version.new(sqlite_version) < Gem::Version.new("3.34")
    issues << "SQLite #{sqlite_version} — FTS5 trigram 토크나이저는 3.34+ 필요 (한국어 검색 부정확)"
  end

  if tables.include?(:entries_fts) && tables.include?(:entries)
    fts_total = db[:entries_fts].count
    entries_total = db[:entries].count
    if fts_total == entries_total
      puts "  ✅ FTS5 entries_fts: #{fts_total}건 (entries와 일치)"
    else
      diff = entries_total - fts_total
      puts "  ⚠  FTS5 entries_fts: #{fts_total}건 vs entries #{entries_total}건 (차이 #{diff}) — IndexRepo 동기화 누락 가능"
      issues << "FTS5 인덱스 entries 동기화 누락 (#{diff}건) — `bundle exec rake vault:reindex` 권장"
    end
  elsif tables.include?(:entries) && !tables.include?(:entries_fts)
    puts "  ⚠  FTS5 entries_fts 테이블 없음 — bundle exec rake db:setup 필요"
    issues << "FTS5 entries_fts 테이블 없음 — `bundle exec rake db:setup` 필요"
  end

  # 깨진 위키링크가 많으면 안내
  if tables.include?(:links)
    broken_count = db[:links].where(target_id: nil).count
    total = db[:links].count
    if total > 0 && broken_count.to_f / total > 0.3
      issues << "위키링크 #{broken_count}/#{total}건 깨짐 (#{(broken_count.to_f / total * 100).round}%) — 타겟 필기·기록 제목 확인"
    end
  end
rescue => e
  puts "  ❌ 연결 실패: #{e.message}"
  issues << "DB 연결 실패: #{e.message}"
end

# 5. 웹 (컨트롤러·라우트 카운트 — 부팅 직후 모든 컨트롤러가 로드되었는지 확인)
puts "\n[웹]"
begin
  # 사용자 향 sub-controller만 (ApplicationController는 base이므로 제외)
  sub_controllers = Sowing::Controllers.constants
    .map { |c| Sowing::Controllers.const_get(c) }
    .select { |c| c.is_a?(Class) && c < Sowing::Controllers::ApplicationController }

  puts "  컨트롤러: #{sub_controllers.size}개 (#{sub_controllers.map { |c| c.name.split("::").last }.sort.join(", ")})"

  all_classes = sub_controllers + [Sowing::Application]
  by_verb = Hash.new(0)
  all_classes.each do |klass|
    klass.routes.each { |verb, list| by_verb[verb] += list.size }
  end
  total_routes = by_verb.values.sum
  verbs_summary = by_verb.sort.map { |v, c| "#{v} #{c}" }.join(", ")
  puts "  라우트: #{total_routes}개 (#{verbs_summary})"
rescue => e
  puts "  ❌ 라우팅 진단 실패: #{e.message}"
end

# 6. 볼트 무결성 (Phase 2에서 강화)
puts "\n[볼트 무결성]"
vault = Sowing::Infrastructure::Paths.vault_dir
md_count = Dir.glob(File.join(vault, "**/*.md")).size
puts "  마크다운 파일 수: #{md_count}"

[
  ["메모 (00_Inbox/)", File.join(vault, "00_Inbox")],
  ["필기 (20_Notes/)", File.join(vault, "20_Notes")],
  ["기록 (30_Records/)", File.join(vault, "30_Records")]
].each do |label, dir|
  count = File.directory?(dir) ? Dir.glob(File.join(dir, "**/*.md")).size : 0
  puts "  #{label}: #{count}건"
end

trash_dir = File.join(vault, ".sowing/trash")
trash_count = File.directory?(trash_dir) ? Dir.glob(File.join(trash_dir, "**/*.md")).size : 0
puts "  휴지통 (.sowing/trash/): #{trash_count}건"

# 7. 인덱스 ↔ 파일 정합성 (간단)
if defined?(db) && db.tables.include?(:entries)
  # md_count는 .sowing/(휴지통·충돌백업) 포함이므로 그것을 제외한 활성 파일 수만 비교.
  active_md = md_count - trash_count
  conflicts_dir = File.join(vault, ".sowing/conflicts")
  conflicts_count = File.directory?(conflicts_dir) ? Dir.glob(File.join(conflicts_dir, "**/*.md")).size : 0
  active_md -= conflicts_count

  indexed = db[:entries].count
  diff = active_md - indexed
  if active_md > 0 && diff != 0
    puts "  ⚠  활성 마크다운 #{active_md}건 vs 인덱스 #{indexed}건 (차이 #{diff}) — Sowing.boot_sync! 또는 ConsistencyCheck 권장"
  end
end

# 8. 동기화 / 충돌 (W5)
puts "\n[동기화 / 충돌]"
conflicts_dir = File.join(vault, ".sowing/conflicts")
conflicts_files = File.directory?(conflicts_dir) ? Dir.glob(File.join(conflicts_dir, "**/*.md")) : []
if conflicts_files.empty?
  puts "  ✅ 충돌 백업 없음"
else
  puts "  ⚠  충돌 백업 (.sowing/conflicts/): #{conflicts_files.size}건 — Keep Mine 시 외부본이 보존된 파일들"
  recent = conflicts_files.sort_by { |f| File.mtime(f) }.last(3).reverse
  recent.each do |path|
    rel = Pathname.new(path).relative_path_from(Pathname.new(vault))
    puts "    · #{rel} (#{File.mtime(path).strftime("%Y-%m-%d %H:%M")})"
  end
end

if defined?(Sowing::Sync::Coordinator) && Sowing.respond_to?(:sync_coordinator) && Sowing.sync_coordinator
  state = Sowing.sync_coordinator.running? ? "▶ 실행 중" : "■ 정지"
  puts "  watcher: #{state}"
else
  puts "  watcher: 미가동 (boot_sync! 호출 시 자동 시작)"
end

# 9. 통계 / 성장 (W6)
puts "\n[통계 / 성장]"
begin
  if defined?(db) && db.tables.include?(:daily_stats)
    Sowing::UseCases::AggregateDailyStats.new.call # 최신화
    stats = Sowing::Repositories::StatsRepo.new
    growth = Sowing::Domain::ValueObjects::GrowthStage.new(stats.total_all_time)

    puts "  오늘:     #{stats.today.total_count}건 (💭 #{stats.today.memos_count} · 📝 #{stats.today.notes_count} · 📖 #{stats.today.records_count})"
    puts "  이번 주:  #{stats.this_week}건 (지난 7일)"
    puts "  이번 달:  #{stats.this_month}건"
    puts "  연속:     🔥 #{stats.current_streak}일"
    if growth.next_threshold
      puts "  성장:     #{growth.label} (누적 #{growth.total}건 / 다음 #{growth.next_threshold}건까지 #{growth.remaining_to_next}건)"
    else
      puts "  성장:     #{growth.label} (누적 #{growth.total}건 — 최고 단계)"
    end
  else
    puts "  ⚠  daily_stats 테이블 없음 — bundle exec rake db:setup 필요"
  end
rescue => e
  puts "  ❌ 통계 조회 실패: #{e.message}"
end

# 10. 템플릿 (W6)
puts "\n[템플릿]"
begin
  template_repo = Sowing::Repositories::TemplateRepo.new(vault_dir: Sowing::Infrastructure::Paths.vault_dir)
  templates = template_repo.list
  by_source = templates.group_by(&:source).transform_values(&:size)
  puts "  총 #{templates.size}개 (시스템 #{by_source[:system] || 0} + 사용자 #{by_source[:user] || 0})"
  if templates.size < 12
    puts "  ⚠  시스템 템플릿이 12개 미만 — 프로젝트 templates/ 누락 가능"
  end
rescue => e
  puts "  ❌ 템플릿 조회 실패: #{e.message}"
end

# 11. 온보딩 / 학습 (W7)
puts "\n[온보딩 / 학습]"
begin
  user_settings = Sowing::Infrastructure::Settings.load
  if user_settings["onboarding_completed"]
    completed_at = user_settings["completed_at"]&.slice(0, 10) || "?"
    name = user_settings["user_name"] || "(미설정)"
    puts "  ✅ 온보딩 완료 — #{completed_at}, 사용자: #{name}"
  else
    puts "  ⏳ 온보딩 미완료 — bin/sowing dev 진입 시 마법사 자동 표시"
  end

  if user_settings["tutorial_completed_at"]
    puts "  ✅ 튜토리얼 완료 — #{user_settings["tutorial_completed_at"].slice(0, 10)}"
  else
    step = user_settings["tutorial_step"].to_i
    puts "  ⏳ 튜토리얼 진행 중 — step #{step}/4"
  end

  if defined?(db) && db.tables.include?(:entries)
    sample_count = Sowing::Repositories::IndexRepo.new.find_samples.size
    if sample_count > 0
      puts "  📦 시드된 샘플 #{sample_count}건 — /settings 에서 일괄 삭제 가능"
    end
  end
rescue => e
  puts "  ❌ 학습 상태 조회 실패: #{e.message}"
end

# 12. 가이드 (W7-T05)
puts "\n[동기화 가이드]"
begin
  guides_dir = File.join(Sowing.root, "templates/guides")
  expected = %w[sync_icloud sync_onedrive sync_dropbox sync_syncthing]
  found = expected.select { |s| File.exist?(File.join(guides_dir, "#{s}.md")) }
  if found.size == expected.size
    puts "  ✅ 4종 모두 존재 (iCloud / OneDrive / Dropbox / Syncthing)"
  else
    missing = expected - found
    puts "  ⚠  누락된 가이드: #{missing.join(", ")}"
  end
rescue => e
  puts "  ❌ 가이드 조회 실패: #{e.message}"
end

# 13. MCP 서버 + audit log (Phase 9)
puts "\n[MCP / Audit (Phase 9)]"
begin
  mcp_bin = File.join(Sowing.root, "bin/sowing-mcp")
  if File.exist?(mcp_bin) && File.executable?(mcp_bin)
    puts "  ✅ bin/sowing-mcp 실행 가능"
  else
    puts "  ⚠  bin/sowing-mcp 없거나 실행 권한 없음 — chmod +x bin/sowing-mcp"
    issues << "bin/sowing-mcp 실행 권한 누락 — `chmod +x bin/sowing-mcp`"
  end

  if defined?(Sowing::MCP::Server)
    tool_count = Sowing::MCP::Server::TOOLS.size
    puts "  ✅ 등록된 MCP 도구: #{tool_count}개"
    if tool_count != 12
      puts "    ⚠  Phase 9 기준 12개 — 현재 #{tool_count}개"
    end
  end

  audit_path = Sowing::Infrastructure::Paths.vault_dir.join(".sowing/audit.log")
  if audit_path.exist?
    line_count = audit_path.each_line.count
    actors = audit_path.each_line
      .lazy
      .map { |l| JSON.parse(l)["actor"] rescue nil }
      .reject(&:nil?)
      .group_by(&:itself)
      .transform_values(&:count)
    summary = actors.map { |k, v| "#{k} #{v}" }.join(", ")
    puts "  audit.log: #{line_count}줄 (#{summary.empty? ? "비어 있음" : summary})"
  else
    puts "  audit.log: 없음 (mutation 발생 시 자동 생성)"
  end

  agent_guide = File.join(Sowing.root, "docs/AGENT_GUIDE.md")
  if File.exist?(agent_guide)
    puts "  ✅ docs/AGENT_GUIDE.md 존재 — Claude Desktop / Codex / Continue / Zed 등록 안내"
  else
    issues << "docs/AGENT_GUIDE.md 누락"
  end
rescue => e
  puts "  ❌ MCP 진단 실패: #{e.message}"
end

# 14. Eval Infrastructure (Phase 10)
puts "\n[Eval Infrastructure (Phase 10)]"
begin
  corpus_dir = File.join(Sowing.root, "eval/corpus/teacher_writings")
  if File.directory?(corpus_dir)
    md_count = Dir.glob(File.join(corpus_dir, "**/*.md")).size
    if md_count >= 100
      puts "  ✅ corpus #{md_count}건 (≥ 100 W13-T01 기준)"
    else
      puts "  ⚠  corpus #{md_count}건 — W13-T01 의 100건 기준 미달"
      issues << "eval corpus #{md_count}건 (100 미만) — `bundle exec ruby eval/scripts/generate_corpus.rb` 실행"
    end
  else
    puts "  ⚠  eval/corpus 디렉토리 없음"
    issues << "eval corpus 디렉토리 누락"
  end

  if defined?(Sowing::Eval::Judge)
    dim_count = Sowing::Eval::Judge::ALL_DIMENSIONS.size
    puts "  ✅ Judge 평가 차원 #{dim_count}개 (SCHEMA.md §4 기준 12)"

    backends = %w[FakeBackend OpenAI Anthropic Ollama]
    available = backends.select { |b| Sowing::Eval::Backends.const_defined?(b) }
    puts "  ✅ Judge 백엔드 #{available.size}/4: #{available.join(", ")}"
  end

  if defined?(Sowing::Eval::KoreanDimensions)
    kr_dims = Sowing::Eval::KoreanDimensions.dimensions
    puts "  ✅ 한국어 도메인 차원 #{kr_dims.size}개: #{kr_dims.join(", ")}"
  end

  results_dir = File.join(Sowing.root, "eval/results")
  if File.directory?(results_dir)
    baseline = Dir.glob(File.join(results_dir, "baseline-*.json"))
    other = Dir.glob(File.join(results_dir, "*.json")) - baseline
    msg = "results: baseline #{baseline.size}건 + 로컬 run #{other.size}건"
    msg += " (`bundle exec rake eval:run` 으로 회귀 측정)"
    puts "  #{msg}"
  end
rescue => e
  puts "  ❌ Eval 진단 실패: #{e.message}"
end

# 15. Tier-1 LLM 합성 (Phase 11)
puts "\n[Tier-1 LLM 합성 (Phase 11)]"
begin
  db = Sowing::Infrastructure::DB.connection

  # entities 테이블 (W17-T01)
  if db.table_exists?(:entities) && db.table_exists?(:entity_mentions)
    student_count = db[:entities].where(type: "student").count
    mention_count = db[:entity_mentions].count
    puts "  ✅ entities/entity_mentions 테이블 — student #{student_count}명, mention #{mention_count}건"
  else
    puts "  ⚠  entities/entity_mentions 테이블 누락 — `bundle exec rake db:migrate` 필요"
    issues << "Phase 11 entities 테이블 누락 — db:migrate"
  end

  # 합성기 use case 등록 확인 (W17-T02·T03)
  uc_check = {
    "ExtractEntities (W17-T01)" => Sowing::UseCases.const_defined?(:ExtractEntities),
    "SynthesizeStudentDigest (W17-T02)" => Sowing::UseCases.const_defined?(:SynthesizeStudentDigest),
    "DetectStudentGaps (W17-T03)" => Sowing::UseCases.const_defined?(:DetectStudentGaps)
  }
  uc_check.each do |label, ok|
    puts ok ? "  ✅ #{label}" : "  ⚠  #{label} 누락"
    issues << "Phase 11 use case 누락: #{label}" unless ok
  end

  # /synth 컨트롤러 (W17-T04)
  if Sowing::Controllers.const_defined?(:SynthController)
    puts "  ✅ SynthController (W17-T04) — /synth 검토 UI 등록"
  else
    puts "  ⚠  SynthController 누락 — config/routes.rb 확인"
    issues << "Phase 11 SynthController 누락"
  end

  # 합성 디렉토리 (.sowing/synth/students/) 상태
  synth_dir = Sowing::Infrastructure::Paths.vault_dir.join(".sowing/synth/students")
  if synth_dir.exist?
    pending = Dir.glob(synth_dir.join("*.md")).size
    puts "  검토 대기 중인 합성 디제스트: #{pending}건 (`/synth` 에서 확인)"
  else
    puts "  검토 대기 중인 합성 디제스트: 0건 (디렉토리 미생성, 정상)"
  end

  # 학급 명단 (W17-T03 GapDetector 입력)
  roster = Sowing::Infrastructure::Settings.load["class_roster"]
  if roster.is_a?(Array) && !roster.empty?
    puts "  ✅ class_roster #{roster.size}명 — 대시보드 gap-card 활성"
  else
    puts "  학급 명단 미설정 — `/settings` 에서 등록하면 4주 미언급 학생 알림 표시"
  end

  # audit synth_* 액션 확인 (Phase 12 fine-tuning preference 데이터)
  audit_path = Sowing::Infrastructure::Paths.vault_dir.join(".sowing/audit.log")
  if audit_path.exist?
    synth_actions = audit_path.each_line
      .lazy
      .map { |l| JSON.parse(l)["action"] rescue nil }
      .select { |a| a&.start_with?("synth_") }
      .group_by(&:itself)
      .transform_values(&:count)
    if synth_actions.any?
      summary = synth_actions.map { |k, v| "#{k} #{v}" }.join(", ")
      puts "  audit synth_* 이벤트: #{summary}"
    else
      puts "  audit synth_* 이벤트: 0건 (아직 합성 검토 이력 없음)"
    end
  end
rescue => e
  puts "  ❌ Phase 11 진단 실패: #{e.message}"
end

# 16. Tier-2 LLM 합성 (Phase 12)
puts "\n[Tier-2 LLM 합성 (Phase 12)]"
begin
  uc_check = {
    "SynthesizeSemesterReflection (W21-T01)" => Sowing::UseCases.const_defined?(:SynthesizeSemesterReflection),
    "ExtractLessonPatterns (W21-T02)" => Sowing::UseCases.const_defined?(:ExtractLessonPatterns),
    "DetectContradictions (W21-T03)" => Sowing::UseCases.const_defined?(:DetectContradictions)
  }
  uc_check.each do |label, ok|
    puts ok ? "  ✅ #{label}" : "  ⚠  #{label} 누락"
    issues << "Phase 12 use case 누락: #{label}" unless ok
  end

  # 통합 /synth 대시보드 (W21-T04) — SynthController 의 SYNTH_TYPES 확인
  if Sowing::Controllers::SynthController.const_defined?(:SYNTH_TYPES)
    types = Sowing::Controllers::SynthController::SYNTH_TYPES.keys
    if types.size == 4
      puts "  ✅ /synth 통합 대시보드 (W21-T04) — 4 type: #{types.join(", ")}"
    else
      puts "  ⚠  SynthController::SYNTH_TYPES — #{types.size}/4 type (#{types.join(", ")})"
    end
  end

  # 합성 디렉토리 4종 카운트
  synth_root = Sowing::Infrastructure::Paths.vault_dir.join(".sowing/synth")
  %w[students reflections patterns contradictions].each do |t|
    dir = synth_root.join(t)
    count = dir.exist? ? Dir.glob(dir.join("*.md")).size : 0
    puts "  #{t.ljust(15)} #{count}건"
  end
rescue => e
  puts "  ❌ Phase 12 진단 실패: #{e.message}"
end

puts "\n#{"─" * 60}"
if issues.empty?
  puts "✅ 진단 완료 — 발견된 문제 없음"
else
  puts "⚠  진단 완료 — #{issues.size}개 항목 점검 필요"
  issues.each_with_index { |msg, i| puts "  #{i + 1}. #{msg}" }
  puts ""
  puts "💡 도움말: 위 항목들을 처리한 뒤 doctor를 다시 실행해 보세요."
end
