#!/usr/bin/env ruby
# frozen_string_literal: true

# Sowing 진단 도구.
# 환경 정보, 볼트 무결성, 인덱스 일관성 등을 점검.

require "bundler/setup"
require_relative "../config/application"

puts "🔍 Sowing Doctor — 진단 시작"
puts "─" * 60

# 1. 환경
puts "\n[환경]"
puts "  Ruby:        #{RUBY_VERSION} (#{RUBY_PLATFORM})"
puts "  Sowing:      #{Sowing::VERSION}"
puts "  SOWING_ENV:  #{Sowing.env}"

# 2. 경로
puts "\n[경로]"
puts "  데이터 디렉토리: #{Sowing::Infrastructure::Paths.data_dir}"
puts "  볼트:           #{Sowing::Infrastructure::Paths.vault_dir}"
puts "  DB:             #{Sowing::Infrastructure::Paths.db_path}"

# 3. 디렉토리 존재
puts "\n[디렉토리 상태]"
[
  ["데이터", Sowing::Infrastructure::Paths.data_dir],
  ["볼트", Sowing::Infrastructure::Paths.vault_dir]
].each do |label, path|
  if File.directory?(path)
    puts "  ✅ #{label}: 존재"
  else
    puts "  ⚠  #{label}: 없음 — bin/sowing dev 실행 시 자동 생성됨"
  end
end

# 4. DB 연결 + 인덱스 통계
puts "\n[DB / 인덱스]"
begin
  db = Sowing::Infrastructure::DB.connection
  tables = db.tables
  puts "  ✅ 연결 성공 (테이블 #{tables.size}개: #{tables.sort.join(", ")})"

  if tables.include?(:entries)
    total = db[:entries].count
    by_mode = db[:entries].group_and_count(:mode).all
    puts "  entries 총 #{total}건"
    by_mode.each { |row| puts "    · #{row[:mode]}: #{row[:count]}건" } unless by_mode.empty?
  else
    puts "  ⚠  entries 테이블 없음 — bundle exec rake db:setup 필요"
  end

  if tables.include?(:tags)
    tag_total = db[:tags].count
    puts "  tags 총 #{tag_total}개"
    if tag_total > 0
      top = db[:tags]
        .join(:entry_tags, tag_id: :id)
        .group_and_count(Sequel[:tags][:name])
        .order(Sequel.desc(:count))
        .limit(5)
        .all
      top.each { |row| puts "    · #{row[:name]} (#{row[:count]}회 사용)" }
    end
  end
rescue => e
  puts "  ❌ 연결 실패: #{e.message}"
end

# 5. 볼트 무결성 (Phase 2에서 강화)
puts "\n[볼트 무결성]"
vault = Sowing::Infrastructure::Paths.vault_dir
md_count = Dir.glob(File.join(vault, "**/*.md")).size
puts "  마크다운 파일 수: #{md_count}"

[
  ["메모 (00_Inbox/)", File.join(vault, "00_Inbox")],
  ["필기 (20_Notes/)", File.join(vault, "20_Notes")],
  ["기록 (30_Records/)", File.join(vault, "30_Records")]
].each do |label, dir|
  count = File.directory?(dir) ? Dir.glob(File.join(dir, "**/*.md")).size : 0
  puts "  #{label}: #{count}건"
end

trash_dir = File.join(vault, ".sowing/trash")
trash_count = File.directory?(trash_dir) ? Dir.glob(File.join(trash_dir, "**/*.md")).size : 0
puts "  휴지통 (.sowing/trash/): #{trash_count}건"

# 6. 인덱스 ↔ 파일 정합성 (간단)
if defined?(db) && db.tables.include?(:entries)
  indexed = db[:entries].count
  diff = md_count - indexed
  if md_count > 0 && diff != 0
    puts "  ⚠  마크다운 #{md_count}건 vs 인덱스 #{indexed}건 (차이 #{diff}) — bundle exec rake vault:reindex 권장"
  end
end

puts "\n#{"─" * 60}"
puts "✅ 진단 완료"
