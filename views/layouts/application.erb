<!DOCTYPE html>
<%# Phase 14 W29 — 다크 모드. theme = auto/light/dark. auto 면 data-theme 없음 →
    CSS @media prefers-color-scheme 가 결정. light/dark 면 명시 (OS 무시). %>
<% _theme_value = begin
     Sowing::Core::Settings.load["theme"] || "auto"
   rescue
     "auto"
   end %>
<html lang="ko"<%= " data-theme=\"#{_theme_value}\"" unless _theme_value == "auto" %>>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%# color-scheme: 브라우저에 알림. auto = OS, light/dark = 강제. %>
  <meta name="color-scheme" content="<%= _theme_value == "auto" ? "light dark" : _theme_value %>">
  <title><%= page_title %></title>
  <link rel="stylesheet" href="/css/application.css">

  <!--
    Hotwire (Turbo + Stimulus) CDN 로딩.
    빌드 도구 없이 importmap으로 ESM 직접 import (CLAUDE.md: 빌드 도구 도입 금지).
    importmap 미지원 브라우저용 polyfill로 es-module-shims 동봉.
  -->
  <script async src="https://cdn.jsdelivr.net/npm/es-module-shims@1.10.0/dist/es-module-shims.min.js"></script>
  <script type="importmap">
  {
    "imports": {
      "@hotwired/turbo": "https://cdn.jsdelivr.net/npm/@hotwired/turbo@8.0.4/dist/turbo.es2017-esm.js",
      "@hotwired/stimulus": "https://cdn.jsdelivr.net/npm/@hotwired/stimulus@3.2.2/dist/stimulus.js",
      "controllers/quick_memo": "/js/controllers/quick_memo_controller.js",
      "controllers/quick_search": "/js/controllers/quick_search_controller.js",
      "controllers/editor": "/js/controllers/editor_controller.js",
      "controllers/preview": "/js/controllers/preview_controller.js",
      "controllers/graph": "/js/controllers/graph_controller.js",
      "codemirror": "https://esm.sh/codemirror@6.0.1",
      "@codemirror/lang-markdown": "https://esm.sh/@codemirror/lang-markdown@6.2.5",
      "@codemirror/autocomplete": "https://esm.sh/@codemirror/autocomplete@6.18.1"
    }
  }
  </script>
  <%# Phase 14 W30 — 단축키 사용자 정의. Settings 에서 읽어 window 에 주입.
      JS 컨트롤러가 keydown 리스너에서 참조. %>
  <% _shortcuts = begin
       s = Sowing::Core::Settings.load
       {
         "quick_memo" => s["shortcut_quick_memo"] || "m",
         "quick_search" => s["shortcut_quick_search"] || "k"
       }
     rescue
       {"quick_memo" => "m", "quick_search" => "k"}
     end %>
  <script>
    window.SOWING_SHORTCUTS = <%= _shortcuts.to_json %>;
  </script>

  <script type="module">
    import "@hotwired/turbo"
    import { Application } from "@hotwired/stimulus"
    import QuickMemoController from "controllers/quick_memo"
    import QuickSearchController from "controllers/quick_search"
    import EditorController from "controllers/editor"
    import PreviewController from "controllers/preview"
    import GraphController from "controllers/graph"

    const stimulus = Application.start()
    stimulus.register("quick-memo", QuickMemoController)
    stimulus.register("quick-search", QuickSearchController)
    stimulus.register("editor", EditorController)
    stimulus.register("preview", PreviewController)
    stimulus.register("graph", GraphController)
    window.Stimulus = stimulus
  </script>
</head>
<body>
  <header class="app-header">
    <a href="/" class="brand">Sowing 🌱</a>

    <%# Phase 14 W31 — 모바일 햄버거. JS 0 — checkbox + label + CSS :checked. %>
    <input type="checkbox" id="nav_mobile_toggle" class="nav-mobile-toggle"
           aria-label="메뉴 토글">
    <label for="nav_mobile_toggle" class="nav-mobile-toggle__btn" aria-hidden="true">
      <span class="nav-mobile-toggle__icon">☰</span>
      <span class="nav-mobile-toggle__close">✕</span>
    </label>
    <%# Phase 13 W25-T01 — 동사 중심 IA. 명사 mode (메모·필기·기록) 는 저장 단위로
        그대로 유지하되, 사용자 노출 nav 는 동사 (글쓰기·보기·계획·회고) 5+1 로.
        <details> + CSS :focus-within 으로 JS 0 dropdown. ADR-014 제안. %>
    <nav class="nav-v2" aria-label="주 메뉴">
      <a href="/" class="nav-v2__home">🏠 홈</a>

      <details class="nav-v2__group">
        <summary>🖊 글쓰기</summary>
        <div class="nav-v2__panel">
          <a href="#" onclick="document.querySelector('[data-quick-memo-target=&quot;dialog&quot;]')?.showModal(); return false;">⚡ 빠른 메모 <kbd>⌘⇧M</kbd></a>
          <a href="/write/book">📖 책 기록</a>
          <a href="/write/lecture">🎤 강의·연수</a>
          <a href="/write/emotion">💭 감정 기록</a>
          <a href="/write/student">👤 학생 관찰</a>
          <hr>
          <a href="/memos">📂 메모 목록</a>
          <a href="/notes/new">📝 필기 작성</a>
          <a href="/notes">📂 필기 목록</a>
          <hr>
          <small>🎙 음성 입력 — 빠른 메모 모달 안에서 이용 가능 (Chrome/Edge, ko-KR)</small>
        </div>
      </details>

      <details class="nav-v2__group">
        <summary>📚 쓴 글 보기</summary>
        <div class="nav-v2__panel">
          <a href="/view/recent">🕐 최근 (통합 시간순)</a>
          <a href="/records">📁 기록 (카테고리별)</a>
          <a href="/records/by-category">📊 카테고리 × 연도</a>
          <a href="/records/timeline">📅 Timeline</a>
          <a href="/tags">🏷 태그</a>
          <a href="/graph">🕸 위키링크 그래프</a>
          <a href="/search">🔍 검색</a>
        </div>
      </details>

      <details class="nav-v2__group">
        <summary>🗓 쓸 글 계획</summary>
        <div class="nav-v2__panel">
          <a href="/plans?period=daily">📅 일간 (오늘 할 일)</a>
          <a href="/plans?period=weekly">📋 주간 계획</a>
          <a href="/plans?period=monthly">🎯 월간 로드맵</a>
          <a href="/plans?period=project">🏗 프로젝트</a>
          <a href="/plans?period=semester">🎓 학기 계획</a>
          <hr>
          <a href="/plans/new?period=daily">＋ 새 계획</a>
        </div>
      </details>

      <details class="nav-v2__group">
        <summary>🪞 자기 거울</summary>
        <div class="nav-v2__panel">
          <a href="/synth">🌱 합성기 16종</a>
          <a href="/synth/metrics">📊 사용 지표</a>
          <hr>
          <small>🌅 오늘의 자기 (5축 분석) — W28 예정</small>
        </div>
      </details>

      <%# Phase 16 P16-T04 — 공식 양식 생성 (생기부·상담부·회의록 등) %>
      <details class="nav-v2__group">
        <summary>📋 공식 양식</summary>
        <div class="nav-v2__panel">
          <a href="/generate/student_record">🎓 생기부 (생활기록부)</a>
          <a href="/generate/consultation">🤝 상담부</a>
          <a href="/generate/meeting_minutes">📋 회의록</a>
          <a href="/generate/project_proposal">📑 사업계획서</a>
          <a href="/generate/budget_request">💰 예산요구서</a>
          <hr>
          <a href="/generate">전체 양식 목록</a>
        </div>
      </details>

      <a href="/settings" class="nav-v2__settings">⚙ 설정</a>

      <%# 보조 진입 — 기존 사용자 호환. 새 IA 익숙해지면 W28-T04 에 제거. %>
      <details class="nav-v2__group nav-v2__group--more">
        <summary>···</summary>
        <div class="nav-v2__panel">
          <a href="/templates">📋 템플릿</a>
          <small>기존 라우트는 모두 그대로 작동 — 북마크 호환</small>
        </div>
      </details>
    </nav>
  </header>
  <main><%= yield %></main>

  <%= erb :"memos/_quick_modal", layout: false %>
  <%= erb :"shared/_quick_search_modal", layout: false %>

  <%# Phase 13 W25-T02 — 동사 중심 nav 변경 안내 모달.
      1회 표시 조건: onboarding 완료 + ia_v2_seen_at 미설정 + GET 요청 + nav 노출 경로.
      onboarding 미완료 사용자에겐 안 보임 (튜토리얼 우선 — 정보 과다 회피).
      layout 에서 직접 검사 — Sinatra::Base helpers 상속이 자식 컨트롤러에서
      불완전해 helper 메서드보다 inline 검사가 안전. %>
  <%
    _ia_v2_path = request.path_info
    _ia_v2_show = request.request_method == "GET" &&
                  !_ia_v2_path.start_with?("/onboarding", "/tutorial", "/health") &&
                  begin
                    _s = Sowing::Core::Settings.load
                    _s["onboarding_completed"] == true && _s["ia_v2_seen_at"].nil?
                  rescue
                    false
                  end
  %>
  <% if _ia_v2_show %>
    <%= erb :"shared/_ia_v2_modal", layout: false %>
  <% end %>
</body>
</html>
