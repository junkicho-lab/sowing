<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light">
  <title><%= page_title %></title>
  <link rel="stylesheet" href="/css/application.css">

  <!--
    Hotwire (Turbo + Stimulus) CDN 로딩.
    빌드 도구 없이 importmap으로 ESM 직접 import (CLAUDE.md: 빌드 도구 도입 금지).
    importmap 미지원 브라우저용 polyfill로 es-module-shims 동봉.
  -->
  <script async src="https://cdn.jsdelivr.net/npm/es-module-shims@1.10.0/dist/es-module-shims.min.js"></script>
  <script type="importmap">
  {
    "imports": {
      "@hotwired/turbo": "https://cdn.jsdelivr.net/npm/@hotwired/turbo@8.0.4/dist/turbo.es2017-esm.js",
      "@hotwired/stimulus": "https://cdn.jsdelivr.net/npm/@hotwired/stimulus@3.2.2/dist/stimulus.js",
      "controllers/quick_memo": "/js/controllers/quick_memo_controller.js",
      "controllers/quick_search": "/js/controllers/quick_search_controller.js",
      "controllers/editor": "/js/controllers/editor_controller.js",
      "controllers/preview": "/js/controllers/preview_controller.js",
      "codemirror": "https://esm.sh/codemirror@6.0.1",
      "@codemirror/lang-markdown": "https://esm.sh/@codemirror/lang-markdown@6.2.5",
      "@codemirror/autocomplete": "https://esm.sh/@codemirror/autocomplete@6.18.1"
    }
  }
  </script>
  <script type="module">
    import "@hotwired/turbo"
    import { Application } from "@hotwired/stimulus"
    import QuickMemoController from "controllers/quick_memo"
    import QuickSearchController from "controllers/quick_search"
    import EditorController from "controllers/editor"
    import PreviewController from "controllers/preview"

    const stimulus = Application.start()
    stimulus.register("quick-memo", QuickMemoController)
    stimulus.register("quick-search", QuickSearchController)
    stimulus.register("editor", EditorController)
    stimulus.register("preview", PreviewController)
    window.Stimulus = stimulus
  </script>
</head>
<body>
  <header class="app-header">
    <a href="/" class="brand">Sowing 🌱</a>
    <nav aria-label="주 메뉴">
      <a href="/">홈</a>
      <a href="/memos">메모</a>
      <a href="/notes">필기</a>
      <a href="/records">기록</a>
      <a href="/tags">태그</a>
      <a href="/search">검색</a>
      <a href="/templates">템플릿</a>
      <a href="/settings">설정</a>
    </nav>
  </header>
  <main><%= yield %></main>

  <%= erb :"memos/_quick_modal", layout: false %>
  <%= erb :"shared/_quick_search_modal", layout: false %>
</body>
</html>
