<section class="notes-new">
  <header class="notes-new__header">
    <h1>기록으로 승격</h1>
    <p class="notes-new__hint">
      메모를 기록(영구 보관)으로 키웁니다 — 같은 ID·작성 시각·본문은 그대로,
      카테고리·제목을 부여합니다. 옛 메모는 휴지통으로 이동.
    </p>
  </header>

  <% if @error %>
    <div class="alert alert--error" role="alert"><%= h(@error) %></div>
  <% end %>

  <%# 2026-05-12 — 원본 메모 본문 항상 표시 (자동 보기 창).
      @memo_subject (IndexRepo 에서 읽은 4축 ENUM) 로 분류 라벨 표시. %>
  <% memo_subject_label = @memo_subject ? Sowing::Capture::Item::SUBJECT_LABELS[@memo_subject.to_sym] : nil %>
  <section class="promote-source promote-source--visible" aria-label="원본 메모">
    <header class="promote-source__header">
      <span class="promote-source__label">원본 메모</span>
      <% if memo_subject_label %>
        <span class="promote-source__category">🏷 <%= h(memo_subject_label) %></span>
      <% end %>
      <time class="promote-source__time"><%= h(@memo.created_at.strftime("%Y-%m-%d %H:%M:%S")) %></time>
    </header>
    <pre class="promote-source__body"><%= h(@memo.body) %></pre>
    <% unless @memo.tags.empty? %>
      <p class="promote-source__tags">
        <% @memo.tags.each do |t| %>
          <span class="promote-source__tag">#<%= h(t) %></span>
        <% end %>
      </p>
    <% end %>
  </section>

  <form action="/memos/<%= h(@memo.id) %>/promote_to_record" method="post" class="note-form">
    <div class="field">
      <label for="record_title">제목 <span class="required">*</span></label>
      <input type="text" id="record_title" name="title" value="<%= h(@form[:title]) %>" required autofocus autocomplete="off">
    </div>

    <%# 2026-05-12 — 4축 카테고리 radio. 메모의 subject 가 있으면 해당 4축
        라벨로 자동 prefill (자유 텍스트 카테고리 폐기). %>
    <fieldset class="field record-form__category-group">
      <legend>카테고리 <span class="required">*</span></legend>
      <% prefilled = @form[:category].to_s.strip.empty? ? memo_subject_label : @form[:category] %>
      <% if memo_subject_label %>
        <p class="record-form__category-prefill-hint">
          ✨ 원본 메모의 4축 분류 (<strong><%= h(memo_subject_label) %></strong>) 가 미리 선택되었습니다.
        </p>
      <% end %>
      <div class="record-form__category-options">
        <% [[:person, "👤", "인물"], [:subject, "📚", "교과"],
            [:document, "📄", "문서"], [:identity, "🪞", "정체성"]].each do |key, icon, label| %>
          <label class="record-form__category-option">
            <input type="radio" name="category" value="<%= h(label) %>"
                   <%= prefilled == label ? "checked" : "" %> required>
            <span><%= icon %> <%= h(label) %></span>
          </label>
        <% end %>
      </div>
    </fieldset>

    <div class="field">
      <label for="record_tags">태그 (메모의 태그가 미리 채워짐)</label>
      <input type="text" id="record_tags" name="tags" value="<%= h(@form[:tags]) %>" placeholder="공백 또는 쉼표로 구분" autocomplete="off">
    </div>

    <div class="form-actions">
      <a href="/memos" class="button button--secondary">취소</a>
      <button type="submit" class="button button--primary">기록으로 승격</button>
    </div>
  </form>
</section>
