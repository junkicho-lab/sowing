<%# 빠른 메모 모달.
    4축 분류 chip (인물·교과·문서·정체성) + 분류 없는 일반 chip.
    chip 선택 시 hidden subject input 갱신 → POST /memos 가 subject ENUM 저장.
    (이전 5 subtype slot 시스템 — book/lecture/emotion/student — 폐기, 2026-05-12.) %>
<dialog id="quick_modal"
        class="quick-modal quick-modal--v2"
        data-controller="quick-memo"
        data-quick-memo-target="dialog"
        aria-labelledby="quick_modal_title">
  <form id="quick_modal_form"
        action="/memos"
        method="post"
        data-quick-memo-target="form"
        data-action="turbo:submit-end->quick-memo#onSubmitEnd">
    <header class="quick-modal__header">
      <h2 id="quick_modal_title">🖊 빠른 메모</h2>
      <button type="button"
              class="quick-modal__close"
              aria-label="닫기"
              data-action="click->quick-memo#close">✕</button>
    </header>

    <%# 4축 분류 chip (ADR-016) — native radio button + CSS chip 스타일.
        JS 의존 0 — 브라우저가 form 제출 시 native 으로 subject= 값 전송.
        2026-05-12 — 옛 button + Stimulus 방식 폐기 (브라우저 캐시·Stimulus 인식 이슈 회피). %>
    <div class="quick-modal__subtypes" role="radiogroup" aria-label="4축 분류">
      <% [["", "⚡", "일반"], ["person", "👤", "인물"], ["subject", "📚", "교과"],
          ["document", "📄", "문서"], ["identity", "🪞", "정체성"]].each_with_index do |(value, icon, label), i| %>
        <label class="quick-modal__chip">
          <input type="radio" name="subject" value="<%= h(value) %>" <%= "checked" if i.zero? %>>
          <span><%= icon %> <%= h(label) %></span>
        </label>
      <% end %>
    </div>

    <textarea name="body"
              class="quick-modal__textarea"
              data-quick-memo-target="textarea"
              data-action="keydown->quick-memo#onTextareaKeydown"
              placeholder="지금 떠오른 생각을 적어주세요..."
              rows="5"
              required
              autocomplete="off"></textarea>

    <div id="quick_modal_error" class="quick-modal__error" data-quick-memo-target="error"></div>

    <%# W26-T02 — 음성 입력 (Web Speech API). 브라우저 미지원 시 JS 가 숨김. %>
    <div class="quick-modal__voice" data-quick-memo-target="voice" hidden>
      <button type="button"
              class="quick-modal__voice-btn"
              data-quick-memo-target="voiceBtn"
              data-action="click->quick-memo#toggleVoice"
              aria-label="음성 입력 시작">
        🎙 <span data-quick-memo-target="voiceLabel">음성 입력</span>
      </button>
      <small class="quick-modal__voice-hint">
        ko-KR · 브라우저 내장 STT 사용 (Chrome/Edge). 인터넷 필요 — Whisper.cpp
        로컬 STT 는 W26-T02b 예정.
      </small>
    </div>

    <footer class="quick-modal__footer">
      <span class="quick-modal__hint">
        <kbd>Esc</kbd> 취소 · <kbd>⌘/Ctrl</kbd> + <kbd>Enter</kbd> 저장
      </span>
      <button type="submit" class="quick-modal__submit">저장</button>
    </footer>
  </form>
</dialog>
