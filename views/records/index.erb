<section class="notes-index" aria-labelledby="records_index_heading">
  <header class="notes-index__header">
    <h1 id="records_index_heading">기록</h1>
    <p class="notes-index__count">총 <%= @total %>건<%= " · #{h(@category)}" if @category %></p>
    <p class="notes-index__views">
      <a href="/records/timeline">📊 timeline (30년 평면)</a> ·
      <a href="/records/by-category">📈 카테고리 × 연도</a>
    </p>
    <a href="/records/new" class="button button--primary notes-index__new">+ 새 기록</a>
  </header>

  <% unless @categories.empty? %>
    <nav class="filter-tabs" aria-label="카테고리 필터">
      <a href="/records" class="filter-tabs__link <%= 'filter-tabs__link--active' if @category.nil? %>">전체</a>
      <% @categories.each do |c| %>
        <a href="/records?category=<%= h(c) %>"
           class="filter-tabs__link <%= 'filter-tabs__link--active' if @category == c %>"><%= h(c) %></a>
      <% end %>
    </nav>
  <% end %>

  <% if @records.empty? %>
    <div class="empty-state empty-state--inline">
      <% if @total.zero? %>
        <p>
          <% if @category %>
            "<%= h(@category) %>" 카테고리에 아직 기록이 없습니다.
          <% else %>
            아직 작성된 기록이 없습니다.
          <% end %>
        </p>
        <p class="empty-state__hint"><a href="/records/new">+ 첫 기록 작성하기</a></p>
        <p class="empty-state__hint">기록은 자기 경험·통찰을 영구 보관하는 글입니다 — 메모와 필기가 자라난 결과물.</p>
      <% else %>
        <p>이 페이지에 기록이 없습니다.</p>
        <p class="empty-state__hint"><a href="/records<%= "?category=#{h(@category)}" if @category %>">첫 페이지로</a></p>
      <% end %>
    </div>
  <% else %>
    <ul class="note-list">
      <% @records.each do |record| %>
        <%= erb :"records/_card", layout: false, locals: {record: record} %>
      <% end %>
    </ul>
  <% end %>

  <% if @total_pages > 1 %>
    <% category_q = @category ? "&category=#{@category}" : "" %>
    <nav class="pagination" aria-label="페이지 이동">
      <% if @page > 1 %>
        <a class="pagination__link" href="/records?page=<%= @page - 1 %><%= category_q %>" rel="prev">← 이전</a>
      <% else %>
        <span class="pagination__link pagination__link--disabled" aria-disabled="true">← 이전</span>
      <% end %>
      <span class="pagination__info"><%= @page %> / <%= @total_pages %></span>
      <% if @page < @total_pages %>
        <a class="pagination__link" href="/records?page=<%= @page + 1 %><%= category_q %>" rel="next">다음 →</a>
      <% else %>
        <span class="pagination__link pagination__link--disabled" aria-disabled="true">다음 →</span>
      <% end %>
    </nav>
  <% end %>
</section>
