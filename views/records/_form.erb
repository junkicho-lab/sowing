<form action="<%= h(action) %>" method="post" class="note-form">
  <% if defined?(method_override) && method_override %>
    <input type="hidden" name="_method" value="<%= h(method_override) %>">
  <% end %>
  <% if defined?(@expected_file_hash) && @expected_file_hash %>
    <input type="hidden" name="expected_file_hash" value="<%= h(@expected_file_hash) %>">
  <% end %>

  <div class="field">
    <label for="record_title">제목 <span class="required">*</span></label>
    <input type="text"
           id="record_title"
           name="title"
           value="<%= h(form[:title]) %>"
           required
           autofocus
           autocomplete="off">
  </div>

  <fieldset class="field record-form__category-group">
    <legend>카테고리 <span class="required">*</span></legend>
    <%# 2026-05-12 — 자유 텍스트 폐기, 4축 (ADR-016) 한국어 라벨 ENUM 로 제한.
        기존 자유 텍스트 카테고리 entries 는 그대로 유지되나 새 entry 는 4축만. %>
    <div class="record-form__category-options">
      <% [[:person, "👤", "인물"], [:subject, "📚", "교과"],
          [:document, "📄", "문서"], [:identity, "🪞", "정체성"]].each do |key, icon, label| %>
        <label class="record-form__category-option">
          <input type="radio" name="category" value="<%= h(label) %>"
                 <%= form[:category] == label ? "checked" : "" %> required>
          <span><%= icon %> <%= h(label) %></span>
        </label>
      <% end %>
    </div>
    <% existing = form[:category] %>
    <% if existing && !%w[인물 교과 문서 정체성].include?(existing) %>
      <p class="record-form__category-hint">
        ⚠ 기존 카테고리 "<%= h(existing) %>" 는 4축 분류 외 값입니다.
        저장 시 4축 중 하나를 선택해주세요 (자유 텍스트 카테고리 폐기, 2026-05-12).
      </p>
    <% end %>
  </fieldset>

  <div class="field">
    <label for="record_body">본문 <span class="required">*</span></label>
    <%= erb :"shared/_editor_with_preview", layout: false, locals: {id: "record_body", name: "body", value: form[:body], rows: 16, required: true} %>
  </div>

  <div class="field">
    <label for="record_promoted_from">승격된 원본 (선택)</label>
    <input type="text"
           id="record_promoted_from"
           name="promoted_from"
           value="<%= h(form[:promoted_from]) %>"
           placeholder="00_Inbox/2026-05-08_092314.md (메모를 기록으로 키울 때)"
           autocomplete="off">
  </div>

  <div class="field">
    <label for="record_tags">태그</label>
    <input type="text"
           id="record_tags"
           name="tags"
           value="<%= h(form[:tags]) %>"
           placeholder="공백 또는 쉼표로 구분 (선택)"
           autocomplete="off">
  </div>

  <div class="form-actions">
    <a href="/records" class="button button--secondary">취소</a>
    <button type="submit" class="button button--primary">저장</button>
  </div>
</form>
