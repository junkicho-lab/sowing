<section class="dashboard">
  <h1>안녕하세요 👋</h1>
  <p class="dashboard__date">오늘은 <%= korean_today %>입니다.</p>

  <% unless @tutorial_completed %>
    <aside class="dashboard__tutorial-cta">
      <p>
        🌱 <strong>처음이신가요?</strong>
        3분짜리 인터랙티브 튜토리얼로 메모·필기·기록의 흐름을 익혀 보세요.
      </p>
      <a href="/tutorial" class="button button--primary">튜토리얼 시작 →</a>
    </aside>
  <% end %>

  <section class="stats" aria-labelledby="stats_heading">
    <h2 id="stats_heading" class="visually-hidden">기록 통계</h2>
    <ul class="stats__grid">
      <li class="stats__card">
        <span class="stats__label">오늘</span>
        <span class="stats__value"><%= @today_stats.total_count %></span>
        <span class="stats__breakdown">
          💭 <%= @today_stats.memos_count %>
          · 📝 <%= @today_stats.notes_count %>
          · 📖 <%= @today_stats.records_count %>
        </span>
      </li>
      <li class="stats__card">
        <span class="stats__label">이번 주 (지난 7일)</span>
        <span class="stats__value"><%= @week_count %></span>
      </li>
      <li class="stats__card">
        <span class="stats__label">이번 달</span>
        <span class="stats__value"><%= @month_count %></span>
      </li>
      <li class="stats__card stats__card--streak">
        <span class="stats__label">연속 기록</span>
        <span class="stats__value">
          🔥 <%= @streak %><span class="stats__unit">일</span>
        </span>
        <% if @streak == 0 %>
          <span class="stats__breakdown">오늘부터 시작!</span>
        <% end %>
      </li>
    </ul>
  </section>

  <%= erb :"dashboard/_growth", layout: false %>

  <%# Phase 13 W27-T02 — 오늘 할 일 위젯 (미완료 daily plans). 없으면 안 표시. %>
  <% if @todays_plans %>
    <aside class="todays-plans" aria-labelledby="todays_plans_heading">
      <h2 id="todays_plans_heading">📅 오늘 할 일 <small>(<%= @todays_plans[:date] %>)</small></h2>
      <p class="todays-plans__hint">
        오늘의 일간 계획 중 <strong><%= @todays_plans[:count] %>건</strong> 미완료 —
        <a href="/plans?period=daily">전체 일간 보기 →</a>
      </p>
      <ul class="todays-plans__list">
        <% @todays_plans[:plans].each do |plan| %>
          <li class="todays-plans__item">
            <a href="/plans/<%= h(plan.id.to_s) %>" class="todays-plans__title">
              <%= h(plan.title) %>
            </a>
            <form action="/plans/<%= h(plan.id.to_s) %>/toggle" method="post"
                  style="display:inline"
                  onsubmit="return confirm('이 계획을 완료 표시할까요? (다시 진행 중으로 되돌릴 수 있습니다.)');">
              <button type="submit" class="todays-plans__check" aria-label="완료 표시">
                ✓ 완료
              </button>
            </form>
          </li>
        <% end %>
      </ul>
    </aside>
  <% end %>

  <% if @gap_summary && @gap_summary[:unmentioned_count] > 0 %>
    <aside class="gap-card" aria-labelledby="gap_heading">
      <h2 id="gap_heading">⚠ 지난 <%= @gap_summary[:weeks_back] %>주간 한 번도 등장 안 한 학생 <strong><%= @gap_summary[:unmentioned_count] %>명</strong></h2>
      <p class="gap-card__hint">학급 명단 <%= @gap_summary[:roster_size] %>명 중 <%= @gap_summary[:mentioned_count] %>명만 기록에 등장. 방치된 학생을 조기에 발견.</p>
      <details class="gap-card__details">
        <summary>미언급 학생 보기</summary>
        <ul class="gap-card__list">
          <% @gap_summary[:unmentioned].each do |name| %>
            <li><%= h(name) %></li>
          <% end %>
        </ul>
      </details>
      <p class="gap-card__action">
        명단 변경: <a href="/settings">설정</a>
      </p>
    </aside>
  <% elsif @gap_summary.nil? %>
    <aside class="gap-card gap-card--prompt">
      <p>💡 학급 명단을 등록하면 지난 4주간 한 번도 언급되지 않은 학생을 자동 알림. <a href="/settings">설정 → 학급 명단</a></p>
    </aside>
  <% end %>

  <aside class="synth-summary <%= "synth-summary--empty" if @synth_summary.nil? %>" aria-labelledby="synth_summary_heading">
    <h2 id="synth_summary_heading">🌱 합성기 검토</h2>
    <% if @synth_summary %>
      <p class="synth-summary__hint">
        검토 대기 중인 합성 결과 <strong><%= @synth_summary[:total] %>건</strong>
        (<%= @synth_summary[:types].size %> type)
        — <a href="/synth">/synth 검토 →</a>
      </p>
      <ul class="synth-summary__list">
        <% @synth_summary[:types].each do |t| %>
          <li class="synth-summary__item">
            <a href="/synth#<%= h(t[:type]) %>" class="synth-summary__chip" title="<%= h(t[:label]) %> — /synth 에서 검토">
              <span class="synth-summary__icon"><%= t[:icon] %></span>
              <span class="synth-summary__label"><%= h(t[:label]) %></span>
              <span class="synth-summary__count"><%= t[:count] %></span>
            </a>
          </li>
        <% end %>
      </ul>
      <% if @synth_summary[:latest] %>
        <p class="synth-summary__latest">
          가장 최근: <code><%= h(@synth_summary[:latest][:path]) %></code>
          <small>(<%= @synth_summary[:latest][:mtime].strftime("%m/%d %H:%M") %>)</small>
        </p>
      <% end %>
    <% else %>
      <p class="synth-summary__hint">
        아직 합성 결과가 없어요. <strong>16 type LLM·결정적 합성기</strong> 로
        학생 디제스트·학기 회고·수업 패턴 등을 자동 정리할 수 있습니다.
        <a href="/synth">🌱 합성기 진입 →</a>
      </p>
    <% end %>
  </aside>

  <aside class="on-this-day <%= "on-this-day--empty" if @on_this_day.nil? || @on_this_day.empty? %>" aria-labelledby="on_this_day_heading">
    <h2 id="on_this_day_heading">📅 이날의 회고 — <%= Time.now.month %>월 <%= Time.now.day %>일</h2>
    <% if @on_this_day && @on_this_day.any? %>
      <p class="on-this-day__hint">같은 날짜의 과거 기록 <%= @on_this_day.size %>건. 의식적 검색 없이 자연스러운 환기.</p>
      <ul class="on-this-day__list">
        <% @on_this_day.each do |item| %>
          <% e = item[:entry] %>
          <li class="on-this-day__item">
            <span class="on-this-day__year"><%= item[:year] %><sub>(<%= item[:years_ago] %>년 전)</sub></span>
            <% if e.respond_to?(:title) && e.title && !e.title.to_s.empty? %>
              <a href="/<%= e.mode == :memo ? "memos" : (e.mode == :note ? "notes" : "records") %>/<%= h(e.id.to_s) %>"><%= h(e.title) %></a>
            <% else %>
              <a href="/<%= e.mode == :memo ? "memos" : (e.mode == :note ? "notes" : "records") %>/<%= h(e.id.to_s) %>" class="on-this-day__no-title">(제목 없음 — <%= e.mode %>)</a>
            <% end %>
            <% if e.respond_to?(:category) && e.category && !e.category.to_s.empty? %>
              <span class="on-this-day__cat">· <%= h(e.category) %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="on-this-day__hint">
        같은 날짜의 과거 기록이 아직 없어요.
        <strong>30년 누적되면 매일 풍부한 환기</strong> 가 됩니다 — 오늘부터 한 줄씩 쌓아가요.
        <a href="/records/timeline">📊 timeline 뷰로 30년 검색 →</a>
      </p>
    <% end %>
  </aside>

  <section class="recent-memos" aria-labelledby="recent_memos_heading">
    <h2 id="recent_memos_heading">최근 메모</h2>

    <ul id="recent_memos_list" class="memo-list">
      <% @recent_memos.each do |memo| %>
        <%= erb :"memos/_card", layout: false, locals: {memo: memo} %>
      <% end %>
    </ul>

    <% if @recent_memos.empty? %>
      <div class="empty-state empty-state--inline">
        <p>아직 작성된 메모가 없습니다.</p>
        <p class="empty-state__hint">
          <kbd>⌘/Ctrl</kbd> + <kbd>Shift</kbd> + <kbd>M</kbd> 으로 빠른 메모를 시작해 보세요.
        </p>
        <p class="empty-state__hint">
          또는 CLI에서: <code>bin/sowing memo "오늘 1교시 수업이 활기찼다"</code>
        </p>
      </div>
    <% end %>
  </section>
</section>
