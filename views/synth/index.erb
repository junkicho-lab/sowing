<section class="synth" aria-labelledby="synth_index_heading">
  <header class="synth__header">
    <h1 id="synth_index_heading">합성 결과 검토</h1>
    <p class="synth__lede">
      LLM 또는 결정적 합성으로 만든 4종 산출물입니다.
      검토 후 정식 기록으로 <strong>수락</strong>하거나, 휴지통으로 <strong>거절</strong>하세요.
    </p>
    <p class="synth__notice">
      <span class="synth-badge synth-badge--llm">LLM 합성</span>
      자동 작성된 초안 — 사용자 명시 클릭 없이는 정식 기록이 되지 않습니다 (ADR-013).
    </p>
    <p class="synth__lede">
      <a href="/synth/metrics">📊 사용 지표 보기</a> — 수락률 + type 별 활용 + 주별 추이 (베타 검증용).
    </p>
  </header>

  <% if @flash %>
    <div class="alert alert--info" role="status"><%= h(@flash) %></div>
  <% end %>

  <% total_count = @all_synth.values.map(&:size).sum %>
  <% if total_count.zero? %>
    <div class="empty-state empty-state--inline">
      <p>현재 검토 대기 중인 합성 결과가 없습니다.</p>
      <p class="empty-state__hint">
        아래 4 종 합성기로 첫 디제스트를 생성해 보세요.
      </p>
    </div>
  <% end %>

  <% @synth_types.each do |type, meta| %>
    <% items = @all_synth[type] %>
    <details class="synth-section" <%= "open" if items.any? %>>
      <summary class="synth-section__summary">
        <span class="synth-section__icon"><%= meta[:icon] %></span>
        <span class="synth-section__label"><%= h(meta[:label]) %></span>
        <span class="synth-section__count">(<%= items.size %>건)</span>
      </summary>

      <div class="synth-section__body">
        <% if items.empty? %>
          <p class="empty-state__hint">아직 생성된 <%= h(meta[:label]) %>이 없습니다.</p>
        <% else %>
          <ul class="synth-list">
            <% items.each do |s| %>
              <li class="synth-card">
                <header class="synth-card__header">
                  <h3 class="synth-card__title">
                    <a href="/synth/<%= h(type) %>/<%= h(s[:slug]) %>">
                      <%= h(s[:fm]["title"] || s[:slug]) %>
                    </a>
                  </h3>
                  <div class="synth-card__meta">
                    <span class="synth-badge synth-badge--llm">LLM 합성</span>
                    <% if recently_synthed?(s) %>
                      <span class="synth-badge synth-badge--recent">이번 주 새로 합성</span>
                    <% end %>
                    <% if s[:fm]["synth_model"] %>
                      <span class="synth-card__model"><%= h(s[:fm]["synth_model"]) %></span>
                    <% end %>
                    <% if s[:fm]["synth_at"] %>
                      <time datetime="<%= h(s[:fm]["synth_at"]) %>"><%= h(s[:fm]["synth_at"][0, 10]) %></time>
                    <% end %>
                    <% if s[:fm]["synth_source_count"] %>
                      <span class="synth-card__sources">출처 <%= s[:fm]["synth_source_count"] %>건</span>
                    <% end %>
                  </div>
                </header>

                <p class="synth-card__excerpt">
                  <%= h(s[:body].to_s.strip[0, 160]) %><%= "…" if s[:body].to_s.strip.length > 160 %>
                </p>

                <div class="synth-card__actions">
                  <a href="/synth/<%= h(type) %>/<%= h(s[:slug]) %>" class="button button--ghost">자세히 보기</a>
                  <form action="/synth/<%= h(type) %>/<%= h(s[:slug]) %>/accept" method="post"
                        style="display:inline"
                        onsubmit="return confirm('수락 — 정식 기록(30_Records/{YYYY}/<%= h(meta[:accept_category]) %>)으로 이동합니다. 계속할까요?');">
                    <button type="submit" class="button button--primary">수락</button>
                  </form>
                  <form action="/synth/<%= h(type) %>/<%= h(s[:slug]) %>/reject" method="post"
                        style="display:inline"
                        onsubmit="return confirm('거절 — 휴지통(.sowing/trash)으로 이동합니다. 계속할까요?');">
                    <button type="submit" class="button button--danger">거절</button>
                  </form>
                </div>
              </li>
            <% end %>
          </ul>
        <% end %>

        <%# 생성 폼 — type별 별도 디자인 %>
        <div class="synth-section__generate">
          <% case type
             when "students" %>
            <form action="/synth/students/__SLUG__/generate" method="post" class="synth-generate-form"
                  data-controller="synth-student-form">
              <label>
                학생 이름 (entity 인덱싱 필수):
                <input type="text" name="student_name" required placeholder="예: 민준"
                       data-action="input->synth-student-form#updateAction">
              </label>
              <button type="submit" class="button button--ghost">생성/재생성</button>
              <small class="synth-generate-form__hint">학생이 본문에 등장한 entries 가 없으면 실패합니다.</small>
            </form>
          <% when "reflections" %>
            <form action="/synth/reflections/generate" method="post" class="synth-generate-form">
              <label>
                학기 라벨:
                <input type="text" name="semester_label" required placeholder="예: 2026-1">
              </label>
              <label>
                시작 (선택, default = 6개월 전):
                <input type="datetime-local" name="since">
              </label>
              <label>
                종료 (선택, default = 지금):
                <input type="datetime-local" name="until_time">
              </label>
              <button type="button" class="button button--ghost button--small"
                      data-synth-preset="all-time"
                      title="시작 = 1990-01-01, 종료 = 지금 (30년 누적 시 사용)">
                📅 전체 기간 (30년)
              </button>
              <button type="submit" class="button button--ghost">생성/재생성</button>
              <small class="synth-generate-form__hint">기간 내 entries 가 5건 미만이면 실패합니다.</small>
            </form>
          <% when "patterns" %>
            <form action="/synth/patterns/lessons/generate" method="post" class="synth-generate-form">
              <button type="submit" class="button button--ghost">생성/재생성 (수업 카테고리 기준)</button>
              <small class="synth-generate-form__hint">기본 카테고리: 수업 / 수업회고 / lessons / 도덕 / 도덕수업.</small>
            </form>
          <% when "contradictions" %>
            <form action="/synth/contradictions/observations/generate" method="post" class="synth-generate-form">
              <%= erb :"synth/_llm_toggle", layout: false %>
              <button type="submit" class="button button--ghost">생성/재생성 (학생 변화 후보)</button>
              <small class="synth-generate-form__hint">학생당 mention 2건 이상 + 반의어 차원 매칭이 필요합니다.</small>
            </form>
          <% when "consultations" %>
            <form action="/synth/consultations/__SLUG__/generate" method="post" class="synth-generate-form"
                  data-controller="synth-consultation-form">
              <label>
                학생 이름:
                <input type="text" name="student_name" required placeholder="예: 민준"
                       data-action="input->synth-consultation-form#updateAction">
              </label>
              <label>
                기간 시작 (선택, default = 6개월 전):
                <input type="datetime-local" name="since">
              </label>
              <label>
                기간 종료 (선택, default = 지금):
                <input type="datetime-local" name="until_time">
              </label>
              <button type="button" class="button button--ghost button--small"
                      data-synth-preset="all-time"
                      title="시작 = 1990-01-01, 종료 = 지금 (30년 누적 시 사용)">
                📅 전체 기간 (30년)
              </button>
              <button type="submit" class="button button--ghost">생성/재생성</button>
              <small class="synth-generate-form__hint">상담 카테고리 entries 또는 학생 mention 2건 이상이 필요합니다.</small>
            </form>
          <% when "assessments" %>
            <form action="/synth/assessments/__SLUG__/generate" method="post" class="synth-generate-form"
                  data-controller="synth-assessment-form">
              <label>
                학생 이름:
                <input type="text" name="student_name" required placeholder="예: 민준"
                       data-action="input->synth-assessment-form#updateAction">
              </label>
              <label>
                기간 시작 (선택, default = 6개월 전):
                <input type="datetime-local" name="since">
              </label>
              <label>
                기간 종료 (선택, default = 지금):
                <input type="datetime-local" name="until_time">
              </label>
              <button type="button" class="button button--ghost button--small"
                      data-synth-preset="all-time"
                      title="시작 = 1990-01-01, 종료 = 지금 (30년 누적 시 사용)">
                📅 전체 기간 (30년)
              </button>
              <button type="submit" class="button button--ghost">생성/재생성</button>
              <small class="synth-generate-form__hint">평가 카테고리 entries 또는 학생 mention 2건 이상 + 평가 키워드 본문 매칭이 필요합니다.</small>
            </form>
          <% when "trainings" %>
            <form action="/synth/trainings/__SLUG__/generate" method="post" class="synth-generate-form"
                  data-controller="synth-training-form">
              <label>
                연수 노트 entry ID (notes/trainings/*.md):
                <input type="text" name="training_id" required placeholder="예: 01ABCD..."
                       data-action="input->synth-training-form#updateAction">
              </label>
              <label>
                추적 기간 (일, default 90):
                <input type="number" name="followup_days" min="7" max="365" placeholder="90">
              </label>
              <button type="submit" class="button button--ghost">생성/재생성</button>
              <small class="synth-generate-form__hint">연수 노트 본문에서 핵심 키워드 추출 → 후속 entries 와 매칭. 키워드 명확할수록 정확.</small>
            </form>
          <% when "weekly" %>
            <form action="/synth/weekly/generate" method="post" class="synth-generate-form">
              <label>
                ISO 주 라벨 (선택, default = 이번 주):
                <input type="text" name="week_label" placeholder="예: 2026-W19">
              </label>
              <label>
                기간 시작 (선택):
                <input type="datetime-local" name="since">
              </label>
              <label>
                기간 종료 (선택):
                <input type="datetime-local" name="until_time">
              </label>
              <button type="submit" class="button button--ghost">생성/재생성 (이번 주)</button>
              <small class="synth-generate-form__hint">아무 입력 없이 누르면 이번 ISO 주 (월~일) 자동 생성.</small>
            </form>
          <% when "orphans" %>
            <form action="/synth/orphans/observations/generate" method="post" class="synth-generate-form">
              <button type="submit" class="button button--ghost">생성/재생성 (1년 lookback)</button>
              <small class="synth-generate-form__hint">backlink 0건 entries 식별. 모든 글이 인용·연결돼 있으면 실패 (좋은 일).</small>
            </form>
          <% when "lesson-series" %>
            <form action="/synth/lesson-series/__SLUG__/generate" method="post" class="synth-generate-form"
                  data-controller="synth-series-form">
              <label>
                키워드 (단원·주제):
                <input type="text" name="keyword" required placeholder="예: 분수 / 협동학습"
                       data-action="input->synth-series-form#updateAction">
              </label>
              <label>
                기간 시작 (선택, default = 6개월 전):
                <input type="datetime-local" name="since">
              </label>
              <label>
                기간 종료 (선택, default = 지금):
                <input type="datetime-local" name="until_time">
              </label>
              <button type="button" class="button button--ghost button--small"
                      data-synth-preset="all-time"
                      title="시작 = 1990-01-01, 종료 = 지금 (30년 누적 시 사용)">
                📅 전체 기간 (30년)
              </button>
              <button type="submit" class="button button--ghost">생성/재생성</button>
              <small class="synth-generate-form__hint">title 또는 본문에 키워드 포함하는 entries 2건 이상 필요. 마지막 entry 후 14일 경과면 "종료된 시리즈" 표시.</small>
            </form>
          <% when "tag-clusters" %>
            <form action="/synth/tag-clusters/topics/generate" method="post" class="synth-generate-form">
              <button type="submit" class="button button--ghost">생성/재생성 (Jaccard ≥ 0.3)</button>
              <small class="synth-generate-form__hint">자주 함께 등장한 태그 페어 → 주제 그룹. 빈도 ≥ 2 인 태그만 후보.</small>
            </form>
          <% when "seasonal" %>
            <form action="/synth/seasonal/current/generate" method="post" class="synth-generate-form"
                  data-controller="synth-seasonal-form">
              <label>
                월 (1~12, 비우면 이번 달):
                <input type="number" name="month" min="1" max="12" placeholder="이번 달"
                       data-action="input->synth-seasonal-form#updateAction">
              </label>
              <button type="submit" class="button button--ghost">생성/재생성</button>
              <small class="synth-generate-form__hint">같은 월 (예: 매년 4월) 의 entries 비교. 연차 1년 미만이면 비교 없이 통계만.</small>
            </form>
          <% when "parent-patterns" %>
            <form action="/synth/parent-patterns/__SLUG__/generate" method="post" class="synth-generate-form"
                  data-controller="synth-parent-patterns-form">
              <label>
                학기 라벨:
                <input type="text" name="semester_label" required placeholder="예: 2026-1"
                       data-action="input->synth-parent-patterns-form#updateAction">
              </label>
              <label>
                기간 시작 (선택):
                <input type="datetime-local" name="since">
              </label>
              <label>
                기간 종료 (선택):
                <input type="datetime-local" name="until_time">
              </label>
              <button type="button" class="button button--ghost button--small"
                      data-synth-preset="all-time">📅 전체 기간 (30년)</button>
              <%= erb :"synth/_llm_toggle", layout: false %>
              <button type="submit" class="button button--ghost">생성/재생성</button>
              <small class="synth-generate-form__hint">학급 전체 학기 상담 분석. 학생별 빈도 + 미상담 학생 + 공통 키워드. (Settings 의 학급 명단 활용 권장.)</small>
            </form>
          <% when "self-patterns" %>
            <form action="/synth/self-patterns/__SLUG__/generate" method="post" class="synth-generate-form"
                  data-controller="synth-self-patterns-form">
              <label>
                기간 라벨:
                <input type="text" name="period_label" required placeholder="예: 2026-1학기 또는 최근-1년"
                       data-action="input->synth-self-patterns-form#updateAction">
              </label>
              <label>
                기간 시작 (선택):
                <input type="datetime-local" name="since">
              </label>
              <label>
                기간 종료 (선택):
                <input type="datetime-local" name="until_time">
              </label>
              <button type="button" class="button button--ghost button--small"
                      data-synth-preset="all-time">📅 전체 기간 (30년)</button>
              <%= erb :"synth/_llm_toggle", layout: false %>
              <button type="submit" class="button button--ghost">생성/재생성</button>
              <small class="synth-generate-form__hint">교사 자신의 집필 패턴 메타-합성. 톤 신호어 + 시간대 + 작성 공백. 단정 0 — 통계와 인용만.</small>
            </form>
          <% when "learning-progress" %>
            <form action="/synth/learning-progress/__SLUG__/generate" method="post" class="synth-generate-form"
                  data-controller="synth-learning-progress-form">
              <label>
                학습 키워드:
                <input type="text" name="keyword" required placeholder="예: 분수 / 협동학습"
                       data-action="input->synth-learning-progress-form#updateAction">
              </label>
              <label>
                기간 시작 (선택, default 6개월 전):
                <input type="datetime-local" name="since">
              </label>
              <label>
                기간 종료 (선택, default 지금):
                <input type="datetime-local" name="until_time">
              </label>
              <button type="button" class="button button--ghost button--small"
                      data-synth-preset="all-time">📅 전체 기간 (30년)</button>
              <button type="submit" class="button button--ghost">생성/재생성</button>
              <small class="synth-generate-form__hint">차시 페이스 + 누적 곡선 + 활동 분포 + 학습 cohort. 진행 중/휴면/종료 자동 판정.</small>
            </form>
          <% when "event-causality" %>
            <form action="/synth/event-causality/__SLUG__/generate" method="post" class="synth-generate-form"
                  data-controller="synth-event-causality-form">
              <label>
                사건 키워드:
                <input type="text" name="event_keyword" required placeholder="예: 협동학습 / 학부모 모임"
                       data-action="input->synth-event-causality-form#updateAction">
              </label>
              <label>
                window 일수 (default 30):
                <input type="number" name="window_days" min="7" max="180" placeholder="30">
              </label>
              <label>
                사건 시점 (선택, 비우면 자동 첫 등장):
                <input type="datetime-local" name="event_at">
              </label>
              <%= erb :"synth/_llm_toggle", layout: false %>
              <button type="submit" class="button button--ghost">생성/재생성</button>
              <small class="synth-generate-form__hint">⚠ <strong>상관 = 인과 아님</strong>. before/after 통계 변화만 표시 — 실제 인과 판단은 사용자 본인.</small>
            </form>
          <% when "self-mirror" %>
            <%# Phase 13 W28-T01 — 자기 거울 5축. slug 는 서버가 'period-date' 자동 생성. %>
            <form action="/synth/self-mirror/auto/generate" method="post" class="synth-generate-form">
              <label>
                기간:
                <select name="period">
                  <option value="daily">📅 오늘 (1일)</option>
                  <option value="weekly">📋 이번 주 (7일)</option>
                </select>
              </label>
              <label>
                날짜 (선택, 비우면 오늘):
                <input type="text" name="date"
                       placeholder="daily=YYYY-MM-DD / weekly=YYYY-Www"
                       pattern="(\d{4}-\d{2}-\d{2}|\d{4}-W\d{2})">
              </label>
              <%= erb :"synth/_llm_toggle", layout: false %>
              <button type="submit" class="button button--ghost">생성/재생성</button>
              <small class="synth-generate-form__hint">5축: 지성·감정·습관·관계·에너지. 짧은 기간 (1일/7일) 의 즉각적 거울. <strong>3건 이상</strong> 작성됐을 때만 의미 있음.</small>
            </form>
          <% end %>
        </div>
      </div>
    </details>
  <% end %>
</section>

<%# 학생 디제스트 폼 — JS 없이 동작하는 fallback (action URL 에 학생 이름 끼워넣기) %>
<script type="module">
  document.querySelectorAll('[data-controller="synth-student-form"]').forEach(form => {
    form.addEventListener('submit', (e) => {
      const input = form.querySelector('input[name="student_name"]')
      const slug = encodeURIComponent(input.value.trim())
      if (!slug) { e.preventDefault(); return }
      form.action = `/synth/students/${slug}/generate`
    })
  })
  document.querySelectorAll('[data-controller="synth-consultation-form"]').forEach(form => {
    form.addEventListener('submit', (e) => {
      const input = form.querySelector('input[name="student_name"]')
      const slug = encodeURIComponent(input.value.trim())
      if (!slug) { e.preventDefault(); return }
      // since/until 폼 인풋은 기본 name 으로 그대로 전송
      form.action = `/synth/consultations/${slug}/generate`
    })
  })
  document.querySelectorAll('[data-controller="synth-assessment-form"]').forEach(form => {
    form.addEventListener('submit', (e) => {
      const input = form.querySelector('input[name="student_name"]')
      const slug = encodeURIComponent(input.value.trim())
      if (!slug) { e.preventDefault(); return }
      form.action = `/synth/assessments/${slug}/generate`
    })
  })
  document.querySelectorAll('[data-controller="synth-training-form"]').forEach(form => {
    form.addEventListener('submit', (e) => {
      const input = form.querySelector('input[name="training_id"]')
      const slug = encodeURIComponent(input.value.trim())
      if (!slug) { e.preventDefault(); return }
      form.action = `/synth/trainings/${slug}/generate`
    })
  })
  document.querySelectorAll('[data-controller="synth-series-form"]').forEach(form => {
    form.addEventListener('submit', (e) => {
      const input = form.querySelector('input[name="keyword"]')
      const slug = encodeURIComponent(input.value.trim())
      if (!slug) { e.preventDefault(); return }
      form.action = `/synth/lesson-series/${slug}/generate`
    })
  })
  document.querySelectorAll('[data-controller="synth-seasonal-form"]').forEach(form => {
    form.addEventListener('submit', (e) => {
      const input = form.querySelector('input[name="month"]')
      const v = input.value.trim()
      if (v) {
        const mm = String(parseInt(v, 10)).padStart(2, '0')
        form.action = `/synth/seasonal/${mm}/generate`
      }
      // 빈 값이면 form.action 기본값 (current) 사용
    })
  })

  // 학부모 상담 패턴 (#9) — semester_label 을 slug 로
  document.querySelectorAll('[data-controller="synth-parent-patterns-form"]').forEach(form => {
    form.addEventListener('submit', (e) => {
      const input = form.querySelector('input[name="semester_label"]')
      const slug = encodeURIComponent(input.value.trim())
      if (!slug) { e.preventDefault(); return }
      form.action = `/synth/parent-patterns/${slug}/generate`
    })
  })

  // 자기 회고 패턴 (#10) — period_label 을 slug 로
  document.querySelectorAll('[data-controller="synth-self-patterns-form"]').forEach(form => {
    form.addEventListener('submit', (e) => {
      const input = form.querySelector('input[name="period_label"]')
      const slug = encodeURIComponent(input.value.trim())
      if (!slug) { e.preventDefault(); return }
      form.action = `/synth/self-patterns/${slug}/generate`
    })
  })

  // 학습 진척 추이 (#11) — keyword 를 slug 로
  document.querySelectorAll('[data-controller="synth-learning-progress-form"]').forEach(form => {
    form.addEventListener('submit', (e) => {
      const input = form.querySelector('input[name="keyword"]')
      const slug = encodeURIComponent(input.value.trim())
      if (!slug) { e.preventDefault(); return }
      form.action = `/synth/learning-progress/${slug}/generate`
    })
  })

  // 사건 인과 추론 (#12) — event_keyword 를 slug 로
  document.querySelectorAll('[data-controller="synth-event-causality-form"]').forEach(form => {
    form.addEventListener('submit', (e) => {
      const input = form.querySelector('input[name="event_keyword"]')
      const slug = encodeURIComponent(input.value.trim())
      if (!slug) { e.preventDefault(); return }
      form.action = `/synth/event-causality/${slug}/generate`
    })
  })

  // "전체 기간 (30년)" preset — since/until_time 인풋 채우기 (30년 시나리오 #5)
  document.querySelectorAll('[data-synth-preset="all-time"]').forEach(btn => {
    btn.addEventListener('click', () => {
      const form = btn.closest('form')
      if (!form) return
      const since = form.querySelector('input[name="since"]')
      const until = form.querySelector('input[name="until_time"]')
      if (since) since.value = '1990-01-01T00:00'
      const now = new Date()
      const isoNow = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')}T${String(now.getHours()).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')}`
      if (until) until.value = isoNow
    })
  })
</script>
